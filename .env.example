CHAT_MODE=api
EMBED_MODE=local

# Локальная chat-модель в Docker Compose запускается через профиль local-chat.
# Если Ollama запущена на хосте, используйте http://host.docker.internal:11434
LOCAL_CHAT_BACKEND=ollama
LOCAL_CHAT_BASE_URL=http://ollama:11434
LOCAL_CHAT_MODEL=qwen2.5:3b
LOCAL_CHAT_TEMPERATURE=0.2
LOCAL_CHAT_TIMEOUT=120
LOCAL_CHAT_NUM_PREDICT=192
LOCAL_CHAT_NUM_CTX=2048
LOCAL_CHAT_NUM_THREAD=8
LOCAL_CHAT_KEEP_ALIVE=10m
LOCAL_CHAT_CACHE=1
LOCAL_CHAT_CACHE_DIR=.cache/local_chat

LOCAL_EMBEDDING_BACKEND=fastembed
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MISTRAL_API_KEY=
